<div class="qd-page qd-pay-page">
  <div class="qd-pay-container">
    {{! 页面标题 }}
    <div class="qd-pay-header">
      <h1>💰 积分充值</h1>
      <p class="user-points">当前积分：<span class="points-value">{{model.userPoints}}</span></p>
    </div>

    {{! DEBUG: 显示当前状态 }}
    <div style="background: yellow; padding: 10px; margin: 10px 0; font-size: 12px;">
      <strong>调试信息：</strong><br>
      alipayEnabled: {{this.alipayEnabled}}<br>
      qrCode: {{this.qrCode}}<br>
      qrCode存在: {{if this.qrCode "是" "否"}}<br>
      orderInfo: {{if this.orderInfo "存在" "不存在"}}<br>
      isCreatingOrder: {{this.isCreatingOrder}}<br>
      paymentSuccess: {{this.paymentSuccess}}<br>
      orderExpired: {{this.orderExpired}}
    </div>

    {{#if this.alipayEnabled}}
      {{#unless this.qrCode}}
        {{! 充值套餐选择 }}
        <div class="qd-pay-packages">
          <h2>选择充值套餐</h2>
          
          {{#if this.hasPackages}}
            <div class="packages-grid">
              {{#each model.packages as |pkg|}}
                <div class="package-card {{if (eq this.selectedPackage pkg) 'selected'}}" {{on "click" (fn this.selectPackage pkg)}}>
                  <div class="package-amount">¥{{pkg.amount}}</div>
                  <div class="package-points">{{pkg.points}} 积分</div>
                  {{#if pkg.bonus}}
                    <div class="package-bonus">赠送 {{pkg.bonus}} 积分</div>
                  {{/if}}
                  {{#if pkg.label}}
                    <div class="package-label">{{pkg.label}}</div>
                  {{/if}}
                </div>
              {{/each}}
            </div>

            {{#if this.selectedPackage}}
              <div class="pay-action">
                <button class="btn btn-primary btn-large" {{on "click" this.createOrder}} disabled={{this.isCreatingOrder}}>
                  {{#if this.isCreatingOrder}}
                    创建订单中...
                  {{else}}
                    立即充值 ¥{{this.selectedPackage.amount}}
                  {{/if}}
                </button>
              </div>
            {{/if}}
          {{else}}
            <div class="no-packages">
              <p>暂无充值套餐，请联系管理员配置</p>
            </div>
          {{/if}}
        </div>
      {{else}}
        {{! 二维码支付界面 }}
        <div class="qd-pay-qrcode">
          {{#if this.paymentSuccess}}
            <div class="payment-success">
              <div class="success-icon">✅</div>
              <h2>支付成功！</h2>
              <p>积分已充值到您的账户</p>
              <p class="success-points">+ {{this.orderInfo.points}} 积分</p>
              <p class="redirect-tip">3秒后自动跳转...</p>
            </div>
          {{else if this.orderExpired}}
            <div class="payment-expired">
              <div class="expired-icon">⏰</div>
              <h2>订单已过期</h2>
              <p>请重新创建订单</p>
              <button class="btn btn-primary" {{on "click" this.cancelOrder}}>重新充值</button>
            </div>
          {{else}}
            <div class="qrcode-display">
              <h2>请使用支付宝扫码支付</h2>
              
              <div class="qrcode-image">
                {{#if (starts-with this.qrCode "MOCK_QR_")}}
                  <div class="mock-qrcode">
                    <p>测试模式二维码</p>
                    <p class="mock-order-no">{{this.qrCode}}</p>
                    <p class="mock-tip">实际生产环境将显示真实支付宝二维码</p>
                  </div>
                {{else}}
                  <div id="qrcode-container" style="text-align: center; padding: 20px;">
                    <canvas id="qrcode-canvas"></canvas>
                  </div>
                  <div style="margin-top: 10px; text-align: center;">
                    <a href="{{this.qrCode}}" target="_blank" class="alipay-link">或点击此链接在手机上打开</a>
                  </div>
                {{/if}}
              </div>

              <div class="order-details">
                <p><strong>订单号：</strong>{{this.orderInfo.out_trade_no}}</p>
                <p><strong>支付金额：</strong>¥{{this.orderInfo.amount}}</p>
                <p><strong>获得积分：</strong>{{this.orderInfo.points}}</p>
                <p class="expire-tip">订单将在 5 分钟后过期</p>
              </div>

              <div class="polling-status">
                {{#if this.isPolling}}
                  <div class="polling-indicator">
                    <span class="spinner"></span>
                    等待支付中...
                  </div>
                {{/if}}
              </div>

              <div class="qrcode-actions">
                <button class="btn btn-default" {{on "click" this.cancelOrder}}>取消订单</button>
              </div>
            </div>
          {{/if}}
        </div>
      {{/unless}}
    {{else}}
      {{! 支付宝未启用 }}
      <div class="alipay-disabled">
        <div class="warning-icon">⚠️</div>
        <h2>支付功能未启用</h2>
        <p>管理员尚未配置支付宝支付，请联系管理员开启此功能</p>
      </div>
    {{/if}}

    {{! 返回按钮 }}
    <div class="qd-pay-footer">
      <button class="btn btn-default" {{on "click" this.goBack}}>
        ← 返回签到页
      </button>
    </div>
  </div>
</div>
